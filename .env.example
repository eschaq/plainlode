# Plainlode backend secrets. Copy to .env and fill in, then source before running:
#   set -a; source .env; set +a
# (.env is gitignored; no python-dotenv, so it must be sourced.)

SCRAPINGDOG_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-20b

# Optional: comma-separated exact origins allowed by CORS in production.
# Localhost is always allowed. Set this in Railway to the deployed frontend URL.
# CORS_ORIGINS=https://plainlode-production.up.railway.app
