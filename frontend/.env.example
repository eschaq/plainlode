# Base URL of the Plainlode FastAPI backend.
#
# Vite inlines VITE_* vars at BUILD time, so this must be set when the frontend
# is built — locally in .env, or as a service variable in Railway (available
# during the build).
#
# Dev  (default if unset): http://127.0.0.1:8000
# Prod (Railway): set to the backend service's public URL, e.g.
#   VITE_API_BASE_URL=https://plainlode-api.up.railway.app
VITE_API_BASE_URL=http://127.0.0.1:8000
